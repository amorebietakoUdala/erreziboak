{% extends 'base.html.twig' %}

{% block title %}
	{{'messages.appTitle' | trans }}
{% endblock title %}

{% block body %}
	<main {{ stimulus_controller('modal', {'title' : 'option.details' | trans }) }}>
      <div class="container-fluid mt-2">
         <h3>{{ 'messages.DNI-NIE-NIF-CIF' | trans }}{{dni}}</h3>
         {% if receipts is defined and receipts|length > 0 %}
            {% include "receipt/_list.html.twig" %}
         {% else %}
            <div class="alert alert-info" role="alert">
               {{ 'messages.noUnpaidReceipts' | trans }}
            </div>
         {% endif %}
      </div>
      {% include "common/_modal.html.twig" %}
	</main>
{% endblock body %}

{% block stylesheets %}
	{{ parent() }}
	{{ encore_entry_link_tags('receipt_search') }}
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	{{ encore_entry_script_tags('receipt_search') }}
{% endblock %}
